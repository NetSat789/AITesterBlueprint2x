<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    TestNG Suite XML - Equivalent to pytest test_suite.py
    Runs all 28 test cases across 5 test classes in defined order.

    Run all tests via Maven:
        mvn test

    Run a single group:
        mvn test -Dgroups=smoke
        mvn test -Dgroups=login
        mvn test -Dgroups=products
        mvn test -Dgroups=cart
        mvn test -Dgroups=checkout
        mvn test -Dgroups=product_detail
        mvn test -Dgroups=regression
-->
<suite name="SauceDemo Regression Suite" verbose="2" parallel="none">

    <test name="Login Tests">
        <classes>
            <class name="com.saucelabs.tests.TestLogin"/>
        </classes>
    </test>

    <test name="Products Tests">
        <classes>
            <class name="com.saucelabs.tests.TestProducts"/>
        </classes>
    </test>

    <test name="Product Detail Tests">
        <classes>
            <class name="com.saucelabs.tests.TestProductDetail"/>
        </classes>
    </test>

    <test name="Cart Tests">
        <classes>
            <class name="com.saucelabs.tests.TestCart"/>
        </classes>
    </test>

    <test name="Checkout Tests">
        <classes>
            <class name="com.saucelabs.tests.TestCheckout"/>
        </classes>
    </test>

</suite>
